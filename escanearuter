#!/bin/bash

# =============================================
# ESCANEARUTER v3.0 - Versión Termux
# Adaptado para funcionar sin permisos root
# =============================================

# Colores para mejor visualización
VERDE='\033[0;32m'
AMARILLO='\033[1;33m'
ROJO='\033[0;31m'
AZUL='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BLANCO='\033[1;37m'
NC='\033[0m' # No Color

# Configuración
ROUTER="192.168.1.1"
MI_IP=""

# Función para mostrar banner
mostrar_banner() {
    clear
    echo -e "${CYAN}"
    echo "╔════════════════════════════════════════════════════╗"
    echo "║              ESCANEARUTER v3.0                     ║"
    echo "║           Versión optimizada para Termux           ║"
    echo "║       Detección avanzada de dispositivos           ║"
    echo "╚════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Función para obtener IP local en Termux
obtener_ip_local_termux() {
    if command -v ip &> /dev/null; then
        MI_IP=$(ip -4 addr show 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v "127.0.0.1" | head -1)
    fi

    if [ -z "$MI_IP" ] && command -v ifconfig &> /dev/null; then
        MI_IP=$(ifconfig 2>/dev/null | grep -Eo 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -Eo '([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | head -1)
    fi

    if [ -z "$MI_IP" ]; then
        echo -e "${AMARILLO}[!] No se pudo detectar IP automáticamente${NC}"
        echo -n "Introduce tu IP local (ej: 192.168.1.10): "
        read MI_IP
    fi

    echo -e "${VERDE}[+] IP Local: $MI_IP${NC}"
    echo -e "${AMARILLO}[!] MAC no disponible (normal en Termux sin root)${NC}"
}

# Función para verificar conectividad
ping_test() {
    echo -e "\n${AZUL}[*] Probando conectividad con el router...${NC}"

    if ping -c 4 $ROUTER > /dev/null 2>&1; then
        ping -c 4 $ROUTER | grep -E "bytes from|packet loss|rtt"
        echo -e "${VERDE}[+] Conexión establecida correctamente${NC}"
    else
        echo -e "${ROJO}[!] No se pudo conectar con el router${NC}"
        echo -e "${AMARILLO}   Verifica que estés en la misma red${NC}"
    fi
}

# Función para escanear puertos del router
escanear_puertos() {
    echo -e "\n${AZUL}[*] Escaneando puertos comunes en $ROUTER...${NC}"
    echo -e "${CYAN}────────────────────────────────────────${NC}"

    PUERTOS=(21 22 23 53 80 443 8080 8443 8000 8081)

    ABIERTOS=0
    for port in "${PUERTOS[@]}"; do
        timeout 1 bash -c "echo >/dev/tcp/$ROUTER/$port" 2>/dev/null
        if [ $? -eq 0 ]; then
            echo -e "${VERDE}[+] Puerto $port: ABIERTO${NC}"
            ABIERTOS=$((ABIERTOS+1))

            case $port in
                21)   echo "     └─ Servicio: FTP" ;;
                22)   echo "     └─ Servicio: SSH" ;;
                23)   echo "     └─ ${ROJO}Servicio: TELNET (inseguro)${NC}" ;;
                53)   echo "     └─ Servicio: DNS" ;;
                80)   echo "     └─ Servicio: HTTP" ;;
                443)  echo "     └─ Servicio: HTTPS" ;;
                8080) echo "     └─ Servicio: HTTP alternativo" ;;
                8443) echo "     └─ Servicio: HTTPS alternativo" ;;
                8000) echo "     └─ Servicio: Puerto de aplicaciones" ;;
                8081) echo "     └─ Servicio: HTTP alternativo" ;;
            esac
        fi
    done

    if [ $ABIERTOS -eq 0 ]; then
        echo -e "${AMARILLO}[-] No se encontraron puertos abiertos${NC}"
    else
        echo -e "\n${VERDE}[+] Total puertos abiertos: $ABIERTOS${NC}"
    fi
}

# =============================================
# IDENTIFICACIÓN DE DISPOSITIVOS POR PUERTOS
# =============================================
identificar_por_puertos() {
    local ip=$1
    local puertos_abiertos=()

    # Puertos a escanear por dispositivo
    local puertos_check=(22 23 80 443 445 548 554 515 631 8080 8443 1883 5000 5001 9100 7547 8888 3389 5900 62078)

    for port in "${puertos_check[@]}"; do
        timeout 0.5 bash -c "echo >/dev/tcp/$ip/$port" 2>/dev/null
        [ $? -eq 0 ] && puertos_abiertos+=($port)
    done

    local tipo="Desconocido"
    local icono="📱"

    # ── Router / Gateway ──────────────────────────────
    if [[ " ${puertos_abiertos[@]} " =~ " 80 " ]] && \
       [[ " ${puertos_abiertos[@]} " =~ " 443 " ]] && \
       [[ " ${puertos_abiertos[@]} " =~ " 53 " ]]; then
        tipo="🌐 Router / Gateway"
        icono="🔷"

    # ── Router sin DNS ────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 7547 " ]]; then
        tipo="🌐 Router (TR-069)"
        icono="🔷"

    # ── NAS / Servidor ────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 445 " ]] && \
         [[ " ${puertos_abiertos[@]} " =~ " 548 " ]]; then
        tipo="🗄️  NAS (Samba + AFP)"
        icono="🖥️"

    elif [[ " ${puertos_abiertos[@]} " =~ " 445 " ]] && \
         [[ " ${puertos_abiertos[@]} " =~ " 80 " ]]; then
        tipo="🗄️  NAS / Servidor"
        icono="🖥️"

    # ── Cámara IP ─────────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 554 " ]]; then
        tipo="📷 Cámara IP (RTSP)"
        icono="📷"

    elif [[ " ${puertos_abiertos[@]} " =~ " 8080 " ]] && \
         [[ ${#puertos_abiertos[@]} -le 2 ]]; then
        tipo="📷 Posible Cámara IP"
        icono="📷"

    # ── Impresora ─────────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 9100 " ]] || \
         [[ " ${puertos_abiertos[@]} " =~ " 515 " ]] || \
         [[ " ${puertos_abiertos[@]} " =~ " 631 " ]]; then
        tipo="🖨️  Impresora"
        icono="🖨️"

    # ── Smart TV / Chromecast ─────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 8008 " ]] || \
         [[ " ${puertos_abiertos[@]} " =~ " 8009 " ]] || \
         [[ " ${puertos_abiertos[@]} " =~ " 5000 " ]]; then
        tipo="📺 Smart TV / Chromecast"
        icono="📺"

    # ── Windows PC ────────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 445 " ]] && \
         [[ " ${puertos_abiertos[@]} " =~ " 3389 " ]]; then
        tipo="💻 PC Windows (RDP activo)"
        icono="💻"

    elif [[ " ${puertos_abiertos[@]} " =~ " 445 " ]]; then
        tipo="💻 PC Windows"
        icono="💻"

    elif [[ " ${puertos_abiertos[@]} " =~ " 3389 " ]]; then
        tipo="💻 PC Windows (RDP)"
        icono="💻"

    # ── Linux / Servidor ──────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 22 " ]] && \
         [[ " ${puertos_abiertos[@]} " =~ " 80 " ]]; then
        tipo="🐧 Servidor Linux (SSH+Web)"
        icono="🖥️"

    elif [[ " ${puertos_abiertos[@]} " =~ " 22 " ]]; then
        tipo="🐧 Linux / Mac (SSH)"
        icono="💻"

    # ── IoT / MQTT ────────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 1883 " ]]; then
        tipo="🏠 Dispositivo IoT (MQTT)"
        icono="🏠"

    # ── VNC (control remoto) ──────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 5900 " ]]; then
        tipo="🖥️  Escritorio remoto (VNC)"
        icono="🖥️"

    # ── iPhone / iPad ─────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 62078 " ]]; then
        tipo="🍎 iPhone / iPad"
        icono="📱"

    # ── Solo web ──────────────────────────────────────
    elif [[ " ${puertos_abiertos[@]} " =~ " 80 " ]] || \
         [[ " ${puertos_abiertos[@]} " =~ " 443 " ]]; then
        tipo="🌐 Dispositivo con web"
        icono="📱"

    # ── Sin puertos detectados ────────────────────────
    elif [ ${#puertos_abiertos[@]} -eq 0 ]; then
        # Usar TTL como último recurso
        local ttl=$(ping -c 1 -W 1 $ip 2>/dev/null | grep -oP 'ttl=\K[0-9]+')
        if [ ! -z "$ttl" ]; then
            if [ $ttl -le 64 ];   then tipo="📱 Smartphone / Tablet"
            elif [ $ttl -le 128 ]; then tipo="💻 PC / Laptop"
            else tipo="📡 Dispositivo de red"
            fi
        fi
    fi

    # Mostrar puertos abiertos encontrados
    local puertos_str=""
    if [ ${#puertos_abiertos[@]} -gt 0 ]; then
        puertos_str=" [puertos: ${puertos_abiertos[*]}]"
    fi

    echo "$icono $tipo$puertos_str"
}

# Función para obtener hostname
obtener_hostname() {
    local ip=$1
    local hostname=""

    if command -v getent &> /dev/null; then
        hostname=$(getent hosts $ip 2>/dev/null | awk '{print $2}' | head -1)
    fi
    if [ -z "$hostname" ] && command -v host &> /dev/null; then
        hostname=$(host $ip 2>/dev/null | grep "domain name" | awk '{print $NF}' | sed 's/\.$//')
    fi

    echo "$hostname"
}

# Función principal para ver dispositivos
ver_dispositivos_termux() {
    echo -e "\n${AZUL}[*] BUSCANDO DISPOSITIVOS EN LA RED${NC}"
    echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"

    RED=$(echo $ROUTER | cut -d'.' -f1-3)
    RESULTADOS="/tmp/dispositivos_$$.txt"

    echo -e "${VERDE}[*] Escaneando red $RED.0/24...${NC}\n"
    echo -e "${CYAN}📡 Fase 1: Descubriendo hosts con ping...${NC}"

    for i in {1..254}; do
        (
            ping -c 1 -W 1 $RED.$i > /dev/null 2>&1
            [ $? -eq 0 ] && echo "$RED.$i" >> $RESULTADOS
        ) &

        if [ $(jobs -p | wc -l) -ge 30 ]; then
            wait -n
        fi
    done
    wait

    echo -e "${CYAN}🔍 Fase 2: Identificando dispositivos por puertos...${NC}\n"

    if [ -f $RESULTADOS ] && [ -s $RESULTADOS ]; then
        sort -t'.' -k4 -n -o $RESULTADOS $RESULTADOS

        echo -e "${VERDE}📱 DISPOSITIVOS ENCONTRADOS:${NC}"
        echo -e "${CYAN}────────────────────────────────────────${NC}"

        CONTADOR=0
        while read ip; do
            [ -z "$ip" ] && continue
            CONTADOR=$((CONTADOR+1))

            # Obtener hostname
            hostname=$(obtener_hostname $ip)

            # Identificar por puertos
            info=$(identificar_por_puertos $ip)

            # Mostrar resultado
            if [ "$ip" = "$ROUTER" ]; then
                echo -e "${VERDE}[$CONTADOR] $ip${NC} ${AMARILLO}(ROUTER)${NC}"
            elif [ "$ip" = "$MI_IP" ]; then
                echo -e "${AZUL}[$CONTADOR] $ip${NC} ${CYAN}(ESTE DISPOSITIVO)${NC}"
            else
                echo -e "${BLANCO}[$CONTADOR] $ip${NC}"
            fi

            [ ! -z "$hostname" ] && echo "   ├─ Nombre: $hostname"
            echo "   └─ $info"
            echo ""

        done < $RESULTADOS

        TOTAL=$(wc -l < $RESULTADOS)
        echo -e "${VERDE}[+] Total dispositivos detectados: $TOTAL${NC}"
    else
        echo -e "${ROJO}[-] No se encontraron dispositivos${NC}"
        echo -e "${AMARILLO}   Prueba con la opción 1 (ping test) primero${NC}"
    fi

    rm -f $RESULTADOS 2>/dev/null
}

# Función para información del router
info_router() {
    echo -e "\n${AZUL}[*] Obteniendo información del router...${NC}"
    echo -e "${CYAN}────────────────────────────────────────${NC}"

    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/80" 2>/dev/null
    HTTP=$?
    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/443" 2>/dev/null
    HTTPS=$?

    if [ $HTTP -eq 0 ] || [ $HTTPS -eq 0 ]; then
        PROTO="http"
        [ $HTTPS -eq 0 ] && PROTO="https"
        echo -e "${VERDE}[+] Interfaz web: $PROTO://$ROUTER${NC}"

        if command -v curl &> /dev/null; then
            TITULO=$(curl -s -L --connect-timeout 5 $PROTO://$ROUTER 2>/dev/null | grep -i "<title>" | sed 's/<[^>]*>//g' | head -1 | cut -c 1-50)
            [ ! -z "$TITULO" ] && echo -e "   └─ Título: $TITULO"
        fi
    else
        echo -e "${AMARILLO}[-] Interfaz web no accesible${NC}"
    fi

    echo -e "\n${CYAN}[*] Servicios detectados:${NC}"
    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/22" 2>/dev/null  && echo -e "   ${VERDE}✓ SSH disponible${NC}"              || echo -e "   ${AMARILLO}✗ SSH no disponible${NC}"
    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/23" 2>/dev/null  && echo -e "   ${ROJO}⚠ TELNET disponible (inseguro)${NC}" || echo -e "   ${VERDE}✓ TELNET no disponible (bien)${NC}"
}

# Función para estadísticas de red
estadisticas_red() {
    echo -e "\n${AZUL}[*] Estadísticas de conexión...${NC}"
    echo -e "${CYAN}────────────────────────────────────────${NC}"

    PING_RESULT=$(ping -c 10 -q $ROUTER 2>/dev/null)
    RTT=$(echo "$PING_RESULT" | grep "rtt" | cut -d'=' -f2)
    LOSS=$(echo "$PING_RESULT" | grep "packet loss" | grep -oP '[0-9]+%')

    if [ ! -z "$RTT" ]; then
        MIN=$(echo $RTT | cut -d'/' -f1)
        AVG=$(echo $RTT | cut -d'/' -f2)
        MAX=$(echo $RTT | cut -d'/' -f3)

        echo -e "${VERDE}[+] Latencia:${NC}"
        echo "   ├─ Mínima: ${MIN}ms"
        echo "   ├─ Media:  ${AVG}ms"
        echo "   └─ Máxima: ${MAX}ms"
        echo -e "${VERDE}[+] Pérdida de paquetes: $LOSS${NC}"

        AVG_NUM=$(echo $AVG | cut -d'.' -f1)
        if [ $AVG_NUM -lt 10 ];   then echo -e "\n${VERDE}[+] Calidad: EXCELENTE 🚀${NC}"
        elif [ $AVG_NUM -lt 30 ]; then echo -e "\n${VERDE}[+] Calidad: BUENA ✓${NC}"
        elif [ $AVG_NUM -lt 60 ]; then echo -e "\n${AMARILLO}[+] Calidad: ACEPTABLE ⚠${NC}"
        else echo -e "\n${ROJO}[+] Calidad: MALA ✗${NC}"
        fi
    else
        echo -e "${ROJO}[-] No se pudieron obtener estadísticas${NC}"
    fi
}

# Función para recomendaciones inteligentes
recomendaciones_inteligentes() {
    echo -e "\n${MAGENTA}════════════════════════════════════════════════════════${NC}"
    echo -e "${MAGENTA}🔒 RECOMENDACIONES PERSONALIZADAS${NC}"
    echo -e "${MAGENTA}════════════════════════════════════════════════════════${NC}"

    RIESGOS=0

    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/23" 2>/dev/null
    if [ $? -eq 0 ]; then
        echo -e "${ROJO}[!] RIESGO CRÍTICO: Telnet (puerto 23) ABIERTO${NC}"
        echo "     └═ Deshabilita Telnet inmediatamente (inseguro)"
        RIESGOS=$((RIESGOS+1))
    fi

    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/21" 2>/dev/null
    if [ $? -eq 0 ]; then
        echo -e "${AMARILLO}[!] RIESGO MEDIO: FTP (puerto 21) ABIERTO${NC}"
        echo "     └═ Usa SFTP en su lugar"
        RIESGOS=$((RIESGOS+1))
    fi

    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/80" 2>/dev/null; HTTP=$?
    timeout 1 bash -c "echo >/dev/tcp/$ROUTER/443" 2>/dev/null; HTTPS=$?

    if [ $HTTP -eq 0 ] && [ $HTTPS -ne 0 ]; then
        echo -e "${AMARILLO}[!] Solo HTTP disponible (sin cifrar)${NC}"
        echo "     └═ Habilita HTTPS para administración segura"
        RIESGOS=$((RIESGOS+1))
    fi

    if [ $RIESGOS -eq 0 ]; then
        echo -e "${VERDE}✅ No se detectaron riesgos inmediatos${NC}"
        echo "   Tu router tiene buena configuración básica"
    else
        echo -e "\n${AMARILLO}⚠ Se detectaron $RIESGOS puntos de mejora${NC}"
    fi

    echo -e "${MAGENTA}════════════════════════════════════════════════════════${NC}"

    if [ $RIESGOS -gt 0 ]; then
        echo -e "\n${CYAN}📋 Consejos rápidos:${NC}"
        echo "   • Actualiza el firmware del router"
        echo "   • Cambia la contraseña por defecto"
        echo "   • Usa WPA2/WPA3 para WiFi"
    fi
}

# Función para exportar resultados
exportar_resultados() {
    echo -e "\n${AZUL}[*] Exportando resultados...${NC}"

    FECHA=$(date +"%Y%m%d_%H%M%S")
    ARCHIVO="escaneo_router_$FECHA.txt"

    {
        echo "=============================================="
        echo "       ESCANEO DE ROUTER - INFORME"
        echo "=============================================="
        echo "Fecha: $(date)"
        echo "Router: $ROUTER"
        echo "IP Local: $MI_IP"
        echo "=============================================="
        echo ""
        echo "--- PUERTOS ABIERTOS ---"
        for port in 21 22 23 53 80 443 8080 8443; do
            timeout 1 bash -c "echo >/dev/tcp/$ROUTER/$port" 2>/dev/null
            [ $? -eq 0 ] && echo "Puerto $port: ABIERTO"
        done

        echo ""
        echo "--- ESTADÍSTICAS ---"
        ping -c 5 $ROUTER 2>&1 | grep -E "packet loss|rtt"

    } > $ARCHIVO

    echo -e "${VERDE}[+] Informe guardado en: $ARCHIVO${NC}"
}

# Función para escaneo completo
escaneo_completo() {
    echo -e "\n${MAGENTA}╔════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║   INICIANDO ESCANEO COMPLETO      ║${NC}"
    echo -e "${MAGENTA}╚════════════════════════════════════╝${NC}"

    ping_test
    echo -e "\n${AMARILLO}Presiona ENTER...${NC}" && read

    escanear_puertos
    echo -e "\n${AMARILLO}Presiona ENTER...${NC}" && read

    info_router
    echo -e "\n${AMARILLO}Presiona ENTER...${NC}" && read

    estadisticas_red
    echo -e "\n${AMARILLO}Presiona ENTER...${NC}" && read

    ver_dispositivos_termux
    echo -e "\n${AMARILLO}Presiona ENTER...${NC}" && read

    recomendaciones_inteligentes

    echo -e "\n${VERDE}[+] Escaneo completo finalizado${NC}"
}

# Función para cambiar IP
cambiar_ip() {
    echo -e "\n${AZUL}[*] IP actual: $ROUTER${NC}"
    echo -n "Nueva IP del router: "
    read nueva_ip

    if [ ! -z "$nueva_ip" ]; then
        if [[ $nueva_ip =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
            ROUTER=$nueva_ip
            echo -e "${VERDE}[+] Router cambiado a: $ROUTER${NC}"
        else
            echo -e "${ROJO}[!] Formato de IP inválido${NC}"
        fi
    fi
}

# =============================================
# PROGRAMA PRINCIPAL
# =============================================

mostrar_banner
obtener_ip_local_termux

echo -e "\n${AZUL}[*] Verificando conectividad...${NC}"
if ping -c 1 -W 2 $ROUTER >/dev/null 2>&1; then
    echo -e "${VERDE}[+] Conectividad OK con $ROUTER${NC}"
else
    echo -e "${ROJO}[!] No se puede alcanzar $ROUTER${NC}"
    echo -e "${AMARILLO}   Verifica que estés en la red WiFi${NC}"
    echo -e "\n${AMARILLO}¿Cambiar IP del router? (s/n): ${NC}"
    read cambiar
    if [ "$cambiar" = "s" ] || [ "$cambiar" = "S" ]; then
        cambiar_ip
    fi
fi

# Menú principal
while true; do
    echo -e "\n${CYAN}════════════════════════════════════════════════════════${NC}"
    echo -e "${AMARILLO}   📡 MENÚ PRINCIPAL - Router: ${VERDE}$ROUTER${NC}"
    echo -e "${CYAN}════════════════════════════════════════════════════════${NC}"
    echo -e "1)  📶 Ping test"
    echo -e "2)  🔌 Escanear puertos"
    echo -e "3)  ℹ️  Información del router"
    echo -e "4)  📊 Estadísticas de red"
    echo -e "5)  📱 Buscar dispositivos"
    echo -e "6)  🔒 Recomendaciones"
    echo -e "7)  💾 Exportar resultados"
    echo -e "8)  🔍 Escaneo completo"
    echo -e "9)  ⚙️  Cambiar IP"
    echo -e "10) 🚪 Salir"
    echo -e "${CYAN}────────────────────────────────────────────────────────${NC}"
    echo -n -e "${VERDE}Selecciona una opción [1-10]: ${NC}"
    read opcion

    case $opcion in
        1) ping_test ;;
        2) escanear_puertos ;;
        3) info_router ;;
        4) estadisticas_red ;;
        5) ver_dispositivos_termux ;;
        6) recomendaciones_inteligentes ;;
        7) exportar_resultados ;;
        8) escaneo_completo ;;
        9) cambiar_ip ;;
        10)
            echo -e "\n${VERDE}¡Hasta luego!${NC}"
            break
            ;;
        *) echo -e "${ROJO}Opción no válida (1-10)${NC}" ;;
    esac

    echo -e "\n${AMARILLO}Presiona ENTER para continuar...${NC}"
    read
    mostrar_banner
    echo -e "${VERDE}[+] Router: $ROUTER | IP Local: $MI_IP${NC}"
done		
